{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ElymBot Plugin Market Catalog",
  "type": "object",
  "required": [
    "sourceId",
    "title",
    "catalogUrl",
    "plugins"
  ],
  "properties": {
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "catalogUrl": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "plugin-entry.schema.json"
      }
    }
  }
}
